POSTGRES_DB=jp_n1_db
POSTGRES_USER=jp_n1_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://jp_n1_user:change_me@db:5432/jp_n1_db?schema=public
NODE_ENV=production
POSTGRES_IMAGE=postgres:16
# Optional: pin build/runtime base image by digest, e.g. node:20-bookworm-slim@sha256:...
NODE_IMAGE=node:20-bookworm-slim
# Optional: pin Prisma tools container image by digest.
PRISMA_TOOLS_IMAGE=node:20-bookworm-slim
# Set 127.0.0.1 if you expose traffic through a reverse proxy on the same host.
APP_BIND_IP=0.0.0.0
